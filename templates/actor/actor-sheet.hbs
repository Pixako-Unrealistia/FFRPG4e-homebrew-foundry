<div class="ffrpg4e-sheet">
  <header class="sheet-header summary-header">
    <div class="identity-summary">
      <h1>{{actor.name}}</h1>
      <div class="summary-line">Level {{system.level}} / {{system.gil}} gil</div>
      <div class="summary-line">{{summary.primaryJob}} / {{summary.secondaryJob}}</div>
    </div>
    <div class="sheet-actions">
      <button type="button" data-action="roll-initiative">Initiative</button>
      <button type="button" data-action="basic-attack">Attack</button>
      <button type="button" data-action="reset-actions">Reset Actions</button>
    </div>
  </header>
  <section class="summary-grid">
    <div class="panel readout-list">
      <h2>Vitals</h2>
      <dl>
        <dt>HP</dt><dd>{{system.resources.hp.value}} / {{system.resources.hp.max}}</dd>
        <dt>MP</dt><dd>{{system.resources.mp.value}} / {{system.resources.mp.max}}</dd>
        <dt>Status</dt><dd>{{summary.status}}</dd>
      </dl>
    </div>
    <div class="panel readout-list">
      <h2>Defense</h2>
      <dl>
        <dt>ARM</dt><dd>{{derived.arm}}</dd>
        <dt>MARM</dt><dd>{{derived.marm}}</dd>
        <dt>AI</dt><dd>{{summary.ai}}</dd>
      </dl>
    </div>
    <div class="panel readout-list">
      <h2>Actions</h2>
      <dl>
        <dt>Quick</dt><dd>{{summary.quickAction}}</dd>
        <dt>Slow</dt><dd>{{summary.slowAction}}</dd>
        <dt>Reaction</dt><dd>{{summary.reaction}}</dd>
      </dl>
    </div>
    <div class="panel readout-list">
      <h2>Stats</h2>
      <dl>
        {{#each statEntries as |stat|}}
        <dt>{{stat.label}}</dt><dd>{{stat.value}} / Lv {{stat.level}}</dd>
        {{/each}}
      </dl>
    </div>
  </section>
  <section class="panel">
    <h2>Challenge</h2>
    <div class="challenge-row">
      <select data-roll-skill>
        {{#each skillOptions as |skill|}}
        <option value="{{skill.key}}">{{skill.label}} ({{skill.statLabel}} {{skill.value}})</option>
        {{/each}}
      </select>
      <input data-roll-difficulty type="number" value="30" min="1" max="99">
      <button type="button" data-action="roll-challenge">Roll</button>
    </div>
  </section>
  {{#if canManageItems}}
  <section class="panel">
    <h2>Add Owned</h2>
    <div class="owned-item-manager-grid">
      <div class="owned-item-manager">
        <label>Spell<select name="manage.spellUuid" data-add-owned-item="spell">
          <option value=""></option>
          {{#each availableItems.spell as |item|}}
          <option value="{{item.uuid}}">{{item.label}}</option>
          {{/each}}
        </select></label>
        <button type="button" data-action="add-owned-item" data-item-type="spell">Add Spell</button>
      </div>
      <div class="owned-item-manager">
        <label>Equipment<select name="manage.equipmentUuid" data-add-owned-item="equipment">
          <option value=""></option>
          {{#each availableItems.equipment as |item|}}
          <option value="{{item.uuid}}">{{item.label}}</option>
          {{/each}}
        </select></label>
        <button type="button" data-action="add-owned-item" data-item-type="equipment">Add Item</button>
      </div>
      <div class="owned-item-manager">
        <label>Ability<select name="manage.abilityUuid" data-add-owned-item="ability">
          <option value=""></option>
          {{#each availableItems.ability as |item|}}
          <option value="{{item.uuid}}">{{item.label}}</option>
          {{/each}}
        </select></label>
        <button type="button" data-action="add-owned-item" data-item-type="ability">Add Ability</button>
      </div>
    </div>
  </section>
  {{/if}}
  <section class="grid two">
    <div class="panel item-list">
      <h2>Abilities Owned</h2>
      {{#each items.abilities as |item|}}
      <div class="item-row">
        <img src="{{item.img}}" alt="{{item.name}}">
        <span><strong>{{item.name}}</strong><small>{{item.system.actionType}} action</small></span>
        <div class="item-actions">
          <button type="button" data-action="roll-item" data-item-id="{{item.id}}">{{item.rollLabel}}</button>
          <span class="item-count">x{{item.quantity}}</span>
          {{#if ../canManageItems}}
          <button type="button" data-action="decrease-owned-item" data-item-id="{{item.id}}">-</button>
          <button type="button" data-action="increase-owned-item" data-item-id="{{item.id}}">+</button>
          <button type="button" data-action="remove-owned-item" data-item-id="{{item.id}}">Remove</button>
          {{/if}}
        </div>
      </div>
      {{else}}
      <p class="empty">No owned abilities.</p>
      {{/each}}
    </div>
    <div class="panel item-list">
      <h2>Spells Owned</h2>
      {{#each items.spells as |item|}}
      <div class="item-row">
        <img src="{{item.img}}" alt="{{item.name}}">
        <span><strong>{{item.name}}</strong><small>{{item.system.mpCost}} MP, {{item.system.element}}</small></span>
        <div class="item-actions">
          <button type="button" data-action="roll-item" data-item-id="{{item.id}}">{{item.rollLabel}}</button>
          <span class="item-count">x{{item.quantity}}</span>
          {{#if ../canManageItems}}
          <button type="button" data-action="decrease-owned-item" data-item-id="{{item.id}}">-</button>
          <button type="button" data-action="increase-owned-item" data-item-id="{{item.id}}">+</button>
          <button type="button" data-action="remove-owned-item" data-item-id="{{item.id}}">Remove</button>
          {{/if}}
        </div>
      </div>
      {{else}}
      <p class="empty">No owned spells.</p>
      {{/each}}
    </div>
  </section>
  <section class="panel item-list">
      <h2>Equipment Owned</h2>
      {{#each items.equipment as |item|}}
      <div class="item-row">
        <img src="{{item.img}}" alt="{{item.name}}">
        <span><strong>{{item.name}}</strong><small>{{item.system.slot}}{{#if item.equipped}} equipped{{/if}}</small></span>
        <div class="item-actions">
          <button type="button" data-action="toggle-equipped" data-item-id="{{item.id}}">{{#if item.equipped}}Unequip{{else}}Equip{{/if}}</button>
          {{#if item.canRoll}}
          <button type="button" data-action="roll-item" data-item-id="{{item.id}}">{{item.rollLabel}}</button>
          {{/if}}
          <span class="item-count">x{{item.quantity}}</span>
          {{#if ../canManageItems}}
          <button type="button" data-action="decrease-owned-item" data-item-id="{{item.id}}">-</button>
          <button type="button" data-action="increase-owned-item" data-item-id="{{item.id}}">+</button>
          <button type="button" data-action="remove-owned-item" data-item-id="{{item.id}}">Remove</button>
          {{/if}}
        </div>
      </div>
      {{else}}
      <p class="empty">No owned equipment.</p>
      {{/each}}
  </section>
  <section class="panel item-list">
    <h2>Other Items Owned</h2>
    {{#each items.other as |item|}}
    <div class="item-row">
      <img src="{{item.img}}" alt="{{item.name}}">
      <span><strong>{{item.name}}</strong><small>{{item.typeLabel}}</small></span>
      <div class="item-actions">
        {{#if item.canRoll}}
        <button type="button" data-action="roll-item" data-item-id="{{item.id}}">{{item.rollLabel}}</button>
        {{/if}}
        <span class="item-count">x{{item.quantity}}</span>
        {{#if ../canManageItems}}
        <button type="button" data-action="decrease-owned-item" data-item-id="{{item.id}}">-</button>
        <button type="button" data-action="increase-owned-item" data-item-id="{{item.id}}">+</button>
        <button type="button" data-action="remove-owned-item" data-item-id="{{item.id}}">Remove</button>
        {{/if}}
      </div>
    </div>
    {{else}}
    <p class="empty">No other owned items.</p>
    {{/each}}
  </section>
  <section class="panel">
    <h2>Edit Identity</h2>
    <div class="identity">
      <label>Name<input class="name" name="name" type="text" value="{{actor.name}}"></label>
      <div class="line">
        <label>Level</label>
        <input name="system.level" type="number" value="{{system.level}}" min="1">
      </div>
      <div class="line">
        <label>Gil</label>
        <input name="system.gil" type="number" value="{{system.gil}}" min="0">
      </div>
    </div>
  </section>
  <section class="grid two">
    <div class="panel">
      <h2>Edit Jobs</h2>
      <label>Primary</label>
      <select name="system.jobs.primary">
        <option value=""></option>
        {{#each jobOptions as |job|}}
        <option value="{{job.key}}" {{#if job.selectedPrimary}}selected{{/if}}>{{job.label}} - {{job.categoryLabel}}</option>
        {{/each}}
      </select>
      <label>Secondary Optional</label>
      <select name="system.jobs.secondary">
        <option value=""></option>
        {{#each jobOptions as |job|}}
        <option value="{{job.key}}" {{#if job.selectedSecondary}}selected{{/if}}>{{job.label}} - {{job.categoryLabel}}</option>
        {{/each}}
      </select>
    </div>
    <div class="panel">
      <h2>Edit Resources</h2>
      <div class="resources">
        <label>HP</label>
        <input name="system.resources.hp.value" type="number" value="{{system.resources.hp.value}}" min="0">
        <span>/</span>
        <input name="system.resources.hp.max" type="number" value="{{system.resources.hp.max}}" min="0">
        <label>MP</label>
        <input name="system.resources.mp.value" type="number" value="{{system.resources.mp.value}}" min="0">
        <span>/</span>
        <input name="system.resources.mp.max" type="number" value="{{system.resources.mp.max}}" min="0">
      </div>
      <div class="resource-suggestion">
        Suggested HP {{derived.hpMax}}, MP {{derived.mpMax}}
        <button type="button" data-action="apply-job-resources">Apply</button>
      </div>
    </div>
  </section>
  <section class="grid two">
    <div class="panel">
      <h2>Edit Stats</h2>
      <div class="stats-grid">
        {{#each statEntries as |stat|}}
        <label>{{stat.label}}<input name="system.stats.{{stat.key}}.value" type="number" value="{{stat.value}}" min="0" max="255"></label>
        <div class="stat-level">Lv {{stat.level}}</div>
        {{/each}}
      </div>
    </div>
    <div class="panel">
      <h2>Edit Defense</h2>
      <div class="resources">
        <label>ARM</label>
        <input name="system.combat.arm" type="number" value="{{system.combat.arm}}" min="0">
        <span>=</span>
        <input type="number" value="{{derived.arm}}" disabled>
        <label>MARM</label>
        <input name="system.combat.marm" type="number" value="{{system.combat.marm}}" min="0">
        <span>=</span>
        <input type="number" value="{{derived.marm}}" disabled>
      </div>
    </div>
  </section>
  <section class="grid two">
    <div class="panel">
      <h2>Edit Combat State</h2>
      <label>KO<input name="system.combat.defeated" type="checkbox" {{#if system.combat.defeated}}checked{{/if}}></label>
      <label>AI<select name="system.combat.ai">{{#each aiOptions as |ai|}}<option value="{{ai.key}}" {{#if ai.selected}}selected{{/if}}>{{ai.label}}</option>{{/each}}</select></label>
      <div class="skills-grid">
        <label>Quick Used<input name="system.combat.actions.quickUsed" type="checkbox" {{#if system.combat.actions.quickUsed}}checked{{/if}}></label>
        <label>Slow Used<input name="system.combat.actions.slowUsed" type="checkbox" {{#if system.combat.actions.slowUsed}}checked{{/if}}></label>
        <label>Reaction Used<input name="system.combat.actions.reactionUsed" type="checkbox" {{#if system.combat.actions.reactionUsed}}checked{{/if}}></label>
      </div>
    </div>
    <div class="panel">
      <h2>Edit Rewards</h2>
      <div class="resources">
        <label>EXP</label>
        <input name="system.combat.rewards.exp" type="number" value="{{system.combat.rewards.exp}}" min="0">
        <span></span>
        <span></span>
        <label>AP</label>
        <input name="system.combat.rewards.ap" type="number" value="{{system.combat.rewards.ap}}" min="0">
      </div>
    </div>
  </section>
  <section class="panel">
    <h2>Edit Elements</h2>
    <div class="skills-grid">
      {{#each elementEntries as |element|}}
      <label>{{element.label}}<select name="system.elements.{{element.key}}">{{#each element.options as |option|}}<option value="{{option.key}}" {{#if option.selected}}selected{{/if}}>{{option.label}}</option>{{/each}}</select></label>
      {{/each}}
    </div>
  </section>
  <section class="panel">
    <h2>Edit Skills</h2>
    <div class="skills-grid">
      {{#each skillOptions as |skill|}}
      <label>{{skill.label}}<input name="system.skills.{{skill.key}}" type="number" value="{{skill.value}}" min="0"></label>
      {{/each}}
    </div>
  </section>
  <section class="panel">
    <h2>Edit Status Effects</h2>
    <div class="status-toggle-grid">
      {{#each statusEntries as |status|}}
      <button type="button" class="status-toggle {{#if status.active}}active{{/if}}" data-action="toggle-status" data-status-key="{{status.key}}">{{status.label}}</button>
      {{/each}}
    </div>
    {{#if unknownStatusText}}
    <p class="status-unknown">Other: {{unknownStatusText}}</p>
    {{/if}}
  </section>
  <section class="panel">
    <h2>Edit Biography</h2>
    <textarea name="system.biography" rows="8">{{system.biography}}</textarea>
  </section>
</div>
