{"_id":"ccdc6b383189c103","name":"Roll FFRPG Challenge","type":"script","author":null,"img":"icons/svg/dice-target.svg","scope":"global","command":"const stat = await Dialog.prompt({title: 'Challenge', content: '<p>Stat value?</p><input name=\"stat\" type=\"number\" value=\"50\" />', callback: html => Number(html.find('[name=stat]').val())}); const roll = await new Roll('3d10 + @stat', {stat}).roll({async: true}); roll.toMessage({speaker: ChatMessage.getSpeaker(), flavor: 'FFRPG Challenge'});","folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.macro.Roll FFRPG Challenge"}}}
{"_id":"847e8efc2e5846ff","name":"Roll Random Encounter","type":"script","author":null,"img":"icons/svg/dice-target.svg","scope":"global","command":"const table = game.tables.find(t => t.name.includes('Encounter')); table.draw();","folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.macro.Roll Random Encounter"}}}
