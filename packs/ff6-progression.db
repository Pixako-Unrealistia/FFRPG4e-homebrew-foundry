{"_id":"defdea0890992666","name":"Relic Mastery","pages":[{"_id":"87f74075d8956e97","name":"Relic Mastery","type":"text","title":{"show":true,"level":1},"text":{"format":1,"content":"<h1>Relic Mastery</h1><p>Relics can unlock signature combat modifications after repeated use.</p>"},"sort":0,"ownership":{"default":-1},"flags":{}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.progression.Relic Mastery"}}}
