{"_id":"7a1311abf6f6bfbd","name":"Level Advancement","pages":[{"_id":"46477139df912c36","name":"Level Advancement","type":"text","title":{"show":true,"level":1},"text":{"format":1,"content":"<h1>Level Advancement</h1><p>Increase character level directly through earned milestones. Earth, Air, Fire, and Water still provide stat levels for action scaling.</p>"},"sort":0,"ownership":{"default":-1},"flags":{}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.progression.Level Advancement"}}}
{"_id":"23d13bb161fa8213","name":"Job Advancement","pages":[{"_id":"f98cffa3728ef00b","name":"Job Advancement","type":"text","title":{"show":true,"level":1},"text":{"format":1,"content":"<h1>Job Advancement</h1><p>A character can advance their primary or secondary job after meaningful use, training, or chapter completion.</p>"},"sort":0,"ownership":{"default":-1},"flags":{}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.progression.Job Advancement"}}}
{"_id":"811dc8db774c9417","name":"Magicite Growth","pages":[{"_id":"374a22332c497cc9","name":"Magicite Growth","type":"text","title":{"show":true,"level":1},"text":{"format":1,"content":"<h1>Magicite Growth</h1><p>Equipped magicite grants a focused stat direction and unlocks related spell training after practice or combat.</p>"},"sort":0,"ownership":{"default":-1},"flags":{}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.progression.Magicite Growth"}}}
{"_id":"40df749e6495bece","name":"Blue Magic Learning","pages":[{"_id":"e11bd60c965b73fb","name":"Blue Magic Learning","type":"text","title":{"show":true,"level":1},"text":{"format":1,"content":"<h1>Blue Magic Learning</h1><p>A Blue Mage can learn monster techniques after seeing, surviving, or analyzing the technique.</p>"},"sort":0,"ownership":{"default":-1},"flags":{}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.progression.Blue Magic Learning"}}}
{"_id":"f82906503c3a6c6d","name":"Time Magic Mastery","pages":[{"_id":"cbe4a5f3fa160f1b","name":"Time Magic Mastery","type":"text","title":{"show":true,"level":1},"text":{"format":1,"content":"<h1>Time Magic Mastery</h1><p>Time magic expands from initiative shifts into action economy, recovery, delay, and battlefield control.</p>"},"sort":0,"ownership":{"default":-1},"flags":{}}],"folder":null,"sort":0,"ownership":{"default":0},"flags":{"ffrpg4e-homebrew-foundry":{"source":"Final Fantasy VI","sourceKey":"ff6.progression.Time Magic Mastery"}}}
